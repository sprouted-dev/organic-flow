---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Style Guide - Organic Flow Color Palette">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8 text-gradient-growth">Organic Flow Color Palette</h1>
    
    <p class="text-xl text-stone-700 dark:text-stone-300 mb-12">
      Our color palette reflects the natural diversity of organic growth - from earth and soil to sky and water, 
      from sunlight to bloom. Each color serves a purpose in our design language.
    </p>

    <!-- Primary Brand Colors -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Core Brand Colors</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="space-y-3">
          <div class="h-24 rounded-lg bg-sprouted-400 flex items-center justify-center text-white font-semibold">
            Sprouted #82b366
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Primary brand color - growth and vitality</p>
        </div>
        <div class="space-y-3">
          <div class="h-24 rounded-lg bg-sky-400 flex items-center justify-center text-white font-semibold">
            Sky #5a9fd4
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Secondary - clarity and flow</p>
        </div>
        <div class="space-y-3">
          <div class="h-24 rounded-lg bg-bloom-400 flex items-center justify-center text-white font-semibold">
            Bloom #ff6b6b
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Accent - energy and transformation</p>
        </div>
      </div>
    </section>

    <!-- Natural Elements -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Natural Elements</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="space-y-3">
          <div class="h-20 rounded-lg bg-earth-400 flex items-center justify-center text-white font-semibold">
            Earth
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Grounding & stability</p>
        </div>
        <div class="space-y-3">
          <div class="h-20 rounded-lg bg-sun-400 flex items-center justify-center text-stone-900 font-semibold">
            Sun
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Energy & vitality</p>
        </div>
        <div class="space-y-3">
          <div class="h-20 rounded-lg bg-autumn-400 flex items-center justify-center text-white font-semibold">
            Autumn
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Maturity & warmth</p>
        </div>
        <div class="space-y-3">
          <div class="h-20 rounded-lg bg-stone-500 flex items-center justify-center text-white font-semibold">
            Stone
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Structure & timeless</p>
        </div>
      </div>
    </section>

    <!-- Gradients -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Gradient Combinations</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-3">
          <div class="h-32 rounded-lg gradient-growth flex items-center justify-center text-white font-semibold shadow-lg">
            Growth Gradient
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Primary gradient - sprouted to sky</p>
        </div>
        <div class="space-y-3">
          <div class="h-32 rounded-lg gradient-sunrise flex items-center justify-center text-white font-semibold shadow-lg">
            Sunrise Gradient
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Vibrant gradient - sun through bloom to sky</p>
        </div>
        <div class="space-y-3">
          <div class="h-32 rounded-lg gradient-autumn flex items-center justify-center text-white font-semibold shadow-lg">
            Autumn Gradient
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Warm gradient - autumn to earth</p>
        </div>
        <div class="space-y-3">
          <div class="h-32 rounded-lg gradient-sky flex items-center justify-center text-white font-semibold shadow-lg">
            Sky Gradient
          </div>
          <p class="text-sm text-stone-600 dark:text-stone-400">Calm gradient - light to deep sky</p>
        </div>
      </div>
    </section>

    <!-- UI Components -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">UI Component Examples</h2>
      
      <!-- Buttons -->
      <div class="mb-8">
        <h3 class="text-lg font-semibold mb-4">Buttons</h3>
        <div class="flex flex-wrap gap-4">
          <button class="px-6 py-3 btn-primary rounded-lg font-medium btn-press">
            Primary Button
          </button>
          <button class="px-6 py-3 btn-sky rounded-lg font-medium btn-press">
            Sky Button
          </button>
          <button class="px-6 py-3 btn-bloom rounded-lg font-medium btn-press">
            Bloom Button
          </button>
          <button class="px-6 py-3 btn-earth rounded-lg font-medium btn-press">
            Earth Button
          </button>
        </div>
      </div>

      <!-- Cards -->
      <div class="mb-8">
        <h3 class="text-lg font-semibold mb-4">Interactive Cards</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-6 surface-spring rounded-lg card-hover-spring">
            <h4 class="font-semibold mb-2">Spring Card</h4>
            <p class="text-stone-600 dark:text-stone-400">Hover for spring effect with green accent</p>
          </div>
          <div class="p-6 surface-sky rounded-lg card-hover-sky">
            <h4 class="font-semibold mb-2">Sky Card</h4>
            <p class="text-stone-600 dark:text-stone-400">Hover for sky effect with blue accent</p>
          </div>
          <div class="p-6 surface-sun rounded-lg card-hover-bloom">
            <h4 class="font-semibold mb-2">Bloom Card</h4>
            <p class="text-stone-600 dark:text-stone-400">Hover for bloom effect with coral accent</p>
          </div>
        </div>
      </div>

      <!-- Badges -->
      <div class="mb-8">
        <h3 class="text-lg font-semibold mb-4">Badges</h3>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 badge-growth rounded-full text-sm">Growth Badge</span>
          <span class="px-3 py-1 badge-sky rounded-full text-sm">Sky Badge</span>
          <span class="px-3 py-1 badge-sun rounded-full text-sm">Sun Badge</span>
          <span class="px-3 py-1 badge-bloom rounded-full text-sm">Bloom Badge</span>
        </div>
      </div>
    </section>

    <!-- Text Gradients -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Text Effects</h2>
      <div class="space-y-4">
        <h3 class="text-3xl font-bold text-gradient-growth">Growth Text Gradient</h3>
        <h3 class="text-3xl font-bold text-gradient-energy">Energy Text Gradient</h3>
      </div>
    </section>

    <!-- Color Usage Guidelines -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Usage Guidelines</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold mb-3">Primary Actions</h3>
          <p class="text-stone-600 dark:text-stone-400 mb-4">
            Use Sprouted green for primary CTAs and important actions. This maintains brand recognition
            while the supporting colors add visual interest.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-3">Information Hierarchy</h3>
          <p class="text-stone-600 dark:text-stone-400 mb-4">
            Sky blues for informational elements, bloom colors for emphasis, earth tones for grounding content,
            and sun colors for highlighting opportunities.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-3">Seasonal Themes</h3>
          <p class="text-stone-600 dark:text-stone-400 mb-4">
            Rotate accent colors based on content type or actual seasons to keep the design fresh
            and aligned with natural cycles.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-3">Accessibility</h3>
          <p class="text-stone-600 dark:text-stone-400 mb-4">
            All color combinations meet WCAG AA standards. Use darker shades for text on light backgrounds
            and lighter shades for text on dark backgrounds.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>